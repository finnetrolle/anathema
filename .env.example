DATABASE_URL="postgresql://postgres:postgres@localhost:5432/anathema?schema=public"
APP_PORT="3001"

# Basic Auth — set both to enable auth, leave empty to disable
APP_BASIC_AUTH_USER=""
APP_BASIC_AUTH_PASSWORD=""

# Base URL of the deployed app, used for Origin validation on sync requests
APP_BASE_URL="http://localhost:3001"

JIRA_CONNECTION_NAME="Primary Jira"
JIRA_BASE_URL="https://your-company.atlassian.net"
JIRA_EMAIL="jira-bot@company.com"
JIRA_API_TOKEN="jira_api_token"
JIRA_DEFAULT_JQL="project = CORE ORDER BY Rank ASC"
JIRA_AUTH_MODE="auto"
JIRA_API_VERSION="auto"
TIMELINE_TIMEZONE="Europe/Moscow"
